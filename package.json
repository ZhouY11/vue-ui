{
    "name": "vue-ui",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "pnpm --filter playground dev",
        "build": "tsx scripts/build.ts",
        "build:ui": "tsx scripts/build.ts ui",
        "build:shared": "tsx scripts/build.ts shared",
        "build:components": "tsx scripts/build.ts components",
        "typecheck": "vue-tsc -b tsconfig.json --noEmit",
        "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
        "changeset": "changeset",
        "version-packages": "changeset version",
        "release:check": "pnpm build",
        "release:publish": "pnpm publish -r --registry http://localhost:4873/ --no-git-checks",
        "release": "pnpm release:check && pnpm release:publish"
    },
    "devDependencies": {
        "@changesets/cli": "2.31.0",
        "@rollup/plugin-commonjs": "29.0.3",
        "@rollup/plugin-node-resolve": "16.0.3",
        "@types/node": "26.0.0",
        "@vitejs/plugin-vue": "catalog:",
        "execa": "9.6.1",
        "jsdom": "catalog:",
        "rollup": "4.62.2",
        "rollup-plugin-esbuild": "6.2.1",
        "tsx": "4.22.4",
        "typescript": "catalog:",
        "unplugin-vue": "7.2.0",
        "vitest": "catalog:",
        "vue-tsc": "catalog:"
    }
}