{
  "name": "@vue-ui/components",
  "buildOptions": {
    "vue": true
  },
  "version": "0.0.3",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
