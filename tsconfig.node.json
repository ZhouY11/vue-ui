{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "types": ["node"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true
  },
  "include": [
    "scripts/**/*.ts",
    "*.config.ts",
    "playground/*.config.ts",
    "packages/*/*.config.ts"
  ]
}